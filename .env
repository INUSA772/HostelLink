# ============================================
# PAYCHANGE PAYMENT GATEWAY CONFIGURATION
# ============================================

# Paychange Merchant ID (Get from Paychange)
PAYCHANGE_MERCHANT_ID=your_merchant_id_here

# Paychange API Key (Get from Paychange)
PAYCHANGE_API_KEY=your_api_key_here

# Paychange Merchant Key (Secret key for signing transactions)
PAYCHANGE_MERCHANT_KEY=your_merchant_key_here

# Paychange API URL (Usually https://api.paychange.co.mw)
PAYCHANGE_API_URL=https://api.paychange.co.mw

# ============================================
# APPLICATION URLS
# ============================================

# Backend API URL (for Paychange callbacks)
API_URL=http://localhost:5000

# Frontend URL (for payment return redirects)
FRONTEND_URL=http://localhost:3000

# ============================================
# MONGODB
# ============================================
MONGO_URI=mongodb://localhost:27017/hostel-booking

# ============================================
# JWT
# ============================================
JWT_SECRET=your_jwt_secret_key_here

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development

# ============================================
# PAYMENT CONFIGURATION
# ============================================

# Fixed platform booking fee in MWK
PLATFORM_BOOKING_FEE=2000

# Payment link expiration time (in seconds)
PAYMENT_LINK_EXPIRY=3600

# Enable payment security features
ENABLE_PAYMENT_VERIFICATION=true

