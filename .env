# ───────────────────────────────────────
# HostelLink Environment Variables
# Copy this to .env and fill in values
# ───────────────────────────────────────



# JWT - Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long
JWT_EXPIRE=30d

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# ─── Paychangu Payment Gateway ───────────
# Get from: https://paychangu.com → Dashboard → API Keys
PAYCHANGU_SECRET_KEY=your_paychangu_secret_key
PAYCHANGU_PUBLIC_KEY=your_paychangu_public_key

# ─── Africa's Talking SMS ─────────────────
# Register at: https://africastalking.com
# For testing use: AT_USERNAME=sandbox (free, no SMS actually sent)
AT_API_KEY=your_africas_talking_api_key
AT_USERNAME=sandbox
AT_SENDER_ID=HOSTELLINK


